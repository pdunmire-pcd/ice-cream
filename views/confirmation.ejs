<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Confirmation</title>
    <link rel="icon" href="images/ice-cream-favicon.jpg">
    <link rel="stylesheet" href="/styles/styles.css">
</head>
<body>
    <main id="confirmation-main">
        <div class="checkmark-circle">✓</div>
        <h1>Thank You for Your Order!</h1>
        <p class="confirmed-message">Your ice cream order has been confirmed</p>

        <div id="confirmation-details">
        <h4>Personal Information</h4>
        <div class="info-grid">
            <span class="info-label">Name:</span>
            <span class="info-value"><%= order.name %></span>
            <span class="info-label">Email:</span>
            <span class="info-value"><%= order.email %></span>
        </div>

        <h4>Order Details</h4>
        <div class="info-grid">
            <span class="info-label">Flavor:</span>
            <span class="info-value"><%= order.flavor %></span>
            <span class="info-label">Cone Type:</span>
            <span class="info-value"><%= order.cone %></span>
            <span class="info-label">Toppings:</span>
            <span class="info-value">
                <% if (order.toppings === 'None') { %>
                    None
                <% } else { %>
                    <% order.toppings.split(', ').forEach(topping => { %>
                        <span class="topping-pill"><%= topping %></span>
                    <% }) %>
                <% } %>
            </span>
        </div>

        <h4>Additional Comments</h4>
        <div class="comment-box">
            <%= order.comment || 'No comments' %>
        </div>
        </div>

        <div class="confirmation-buttons">
            <button id="print-button" onclick="window.print()">Print Order</button>
            <a href="/" id="neworder-button">Place Another Order</a>
        </div>
    </main>
</body>
</html>